DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-generate-with-django-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://equipment_tracker_app:password@localhost:5432/equipment_tracker
CORS_ALLOWED_ORIGINS=http://localhost:5173
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
REFRESH_COOKIE_SECURE=False
REFRESH_COOKIE_SAMESITE=Lax
DEFAULT_FROM_EMAIL=no-reply@equipment-tracker.local
# Leave EMAIL_BACKEND unset in dev to use the console backend (emails print
# to the terminal). Set it to the smtp backend below to send real email from
# local dev too — useful for testing password-reset delivery end-to-end.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# Gmail SMTP relay: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587,
# EMAIL_HOST_USER=youraddress@gmail.com, EMAIL_HOST_PASSWORD=<16-char App Password,
# generated at myaccount.google.com/security → App Passwords — NOT your regular password>
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
# React app origin — used to build the password-reset link sent by email.
FRONTEND_URL=http://localhost:5173
